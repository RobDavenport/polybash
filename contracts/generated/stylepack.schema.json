{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polybash.dev/schemas/stylepack.schema.json",
  "title": "PolyBashStylePack",
  "type": "object",
  "required": [
    "version",
    "id",
    "supportedAssetTypes",
    "budgets",
    "connectorTaxonomy",
    "palettes",
    "rigTemplates",
    "modules"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "supportedAssetTypes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "budgets": {
      "type": "object"
    },
    "connectorTaxonomy": {
      "type": "object"
    },
    "palettes": {
      "type": "array",
      "minItems": 1
    },
    "rigTemplates": {
      "type": "array"
    },
    "modules": {
      "type": "array",
      "minItems": 1
    },
    "decalIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
