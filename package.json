{
  "name": "polybash",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "corepack pnpm --dir plugin build",
    "build:desktop": "corepack pnpm --dir desktop build",
    "test": "corepack pnpm --dir plugin test",
    "test:desktop": "corepack pnpm --dir desktop test",
    "lint": "corepack pnpm --dir plugin lint",
    "typecheck": "corepack pnpm --dir plugin typecheck",
    "typecheck:desktop": "corepack pnpm --dir desktop typecheck",
    "ci": "corepack pnpm lint && corepack pnpm typecheck && corepack pnpm test && corepack pnpm typecheck:desktop && corepack pnpm test:desktop && corepack pnpm build:desktop"
  }
}
